# LocalizaBus — .env.example
# Modelo das variáveis de ambiente. Copie para .env.local ou cadastre na Vercel/Cloudflare.
# Comentário humano: nunca coloque chave real no GitHub público.

# Configure na Vercel em Project Settings > Environment Variables
# Não envie o arquivo .env real para o GitHub.

VITE_TOMTOM_API_KEY=SUA_CHAVE_TOMTOM_AQUI
VITE_ORS_API_KEY=SUA_CHAVE_OPENROUTESERVICE_AQUI
VITE_DFTRANS_WORKER_URL=

VITE_TRANSITLAND_API_KEY=SUA_CHAVE_TRANSITLAND_AQUI
